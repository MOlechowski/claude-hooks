{
  "description": "Block dangerous CLI commands before execution",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/pre_tool_use.py"
          }
        ]
      }
    ]
  }
}
